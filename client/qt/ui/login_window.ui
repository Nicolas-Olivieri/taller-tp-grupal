    <property name="toolTip">
     <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;
&lt;head&gt;
&lt;meta charset=&quot;utf-8&quot; /&gt;
&lt;style type=&quot;text/css&quot;&gt;
/* Fondo completamente oscuro, estilo pergamino quemado / madera */
body {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #2c1a0c, stop:1 #0f0803);
    font-family: 'Times New Roman', 'Georgia', serif;
    font-size: 11pt;
    font-weight: normal;
    color: #f7e5b3;  /* Texto base dorado claro */
    margin: 8px 16px;  /* Más margen a los costados */
    padding: 10px 18px; /* Más relleno interior */
    border: 2px solid #c9a87c; /* Borde dorado/marfil */
    border-radius: 10px;
    box-shadow: 4px 4px 8px rgba(0,0,0,0.6);
}
p {
    margin: 6px 0;
}
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
&lt;p align=&quot;center&quot; style=&quot;margin-top:0; margin-bottom:6px;&quot;&gt;
&lt;span style=&quot;font-size:13pt; font-weight:bold; color:#ffe7a3;&quot;&gt;✦ Pedile a tu amigx que corre el servidor, la dirección IP y puerto en el que lo ejecutó ✦&lt;/span&gt;
&lt;/p&gt;
&lt;p align=&quot;center&quot; style=&quot;margin-bottom:0;&quot;&gt;
&lt;span style=&quot;font-size:11pt; color:#e3c78a;&quot;&gt;Si están conectados en distintas redes, es importante que tu amigx exponga el puerto.&lt;/span&gt;
&lt;/p&gt;
&lt;/body&gt;
&lt;/html&gt;</string>
